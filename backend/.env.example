# Copy this file to ".env" and fill in your own values.
# Never upload the real ".env" file anywhere public.

PORT=3000

# Admin dashboard login (change these before going live!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Long random string used to encrypt the login session cookie.
# You can generate one at https://randomkeygen.com/ or just mash your keyboard.
SESSION_SECRET=please-change-this-to-something-random
